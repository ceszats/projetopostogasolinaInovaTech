# --- CONFIGURAÇÃO DO BACKEND (Servidor) ---
PORT=3000
DATABASE_URL=file:./drizzle/db.sqlite
# Você pode inventar qualquer frase secreta aqui para o desenvolvimento
JWT_SECRET=coloque_uma_frase_aleatoria_aquibbrs
ALLOWED_ORIGINS=http://localhost:8081,http://10.4.15.217:8081

# OAuth real Google/Facebook. Crie os apps nas plataformas e preencha estes valores.
# Configure o redirect/callback autorizado como:
# http://SEU_HOST_API:3000/api/oauth/google/callback
# http://SEU_HOST_API:3000/api/oauth/facebook/callback
OAUTH_REDIRECT_BASE_URL=http://10.4.15.217:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- CONFIGURAÇÃO DO FRONTEND (Expo) ---
# IMPORTANTE: Se for testar no CELULAR FÍSICO, substitua 'localhost' pelo seu IP LOCAL.
# No Windows, abra o terminal e digite 'ipconfig' para achar seu endereço IPv4.
# Exemplo: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:3000

EXPO_PUBLIC_API_BASE_URL=http://10.4.15.217:3000

# Endereços para o Portal de Login (Mantenha igual à API BASE URL se usar o servidor local)
EXPO_PUBLIC_OAUTH_PORTAL_URL=http://10.4.15.217:3000
EXPO_PUBLIC_OAUTH_SERVER_URL=http://10.4.15.217:3000

# Identificadores de teste (Podem ser mantidos assim para desenvolvimento)
EXPO_PUBLIC_APP_ID=fuelmap-manaus-dev
EXPO_PUBLIC_OWNER_OPEN_ID=admin-manaus
EXPO_PUBLIC_OWNER_NAME=FuelMap Manaus Admin
